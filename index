<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cronograma PAU - Filosofía</title>
    <style>
        :root {
            --bg-color: #fcfcf9;
            --primary-text: #2d3436;
            --secondary-text: #636e72;
            --accent-main: #6c5ce7;
            --accent-secondary: #b2bec3;
            --border-color: #dfe6e9;
        }

        body {
            font-family: 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-color);
            margin: 0;
            display: flex;
            justify-content: center;
            color: var(--primary-text);
        }

        .container {
            position: relative;
            width: 1000px;
            padding: 40px;
            min-height: 1600px;
        }

        /* Eje Cronológico */
        .timeline-line {
            position: absolute;
            left: 50px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: var(--border-color);
        }

        /* Nodos */
        .node {
            position: absolute;
            padding: 12px 20px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        /* Estilo Principal (Los 6 autores clave) */
        .node-main {
            border: 2px solid var(--accent-main);
            min-width: 200px;
            z-index: 10;
        }
        .node-main .name { font-weight: 800; font-size: 1.1rem; color: var(--accent-main); }
        .node-main:hover { transform: scale(1.05); box-shadow: 0 5px 15px rgba(108, 92, 231, 0.2); }

        /* Estilo Secundario (Autores entre paréntesis) */
        .node-secondary {
            border: 1px solid var(--accent-secondary);
            min-width: 160px;
            padding: 8px 15px;
            opacity: 0.8;
        }
        .node-secondary .name { font-weight: 600; font-size: 0.9rem; color: var(--secondary-text); }
        .node-secondary:hover { opacity: 1; transform: translateY(-2px); }

        .date { font-size: 0.8rem; color: #95a5a6; margin-top: 2px; }

        /* Modal / Popup */
        #modal-overlay {
            display: none;
            position: fixed;
            top:0; left:0; width:100%; height:100%;
            background: rgba(0,0,0,0.2);
            backdrop-filter: blur(2px);
            z-index: 100;
        }

        #info-card {
            display: none;
            position: fixed;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 420px;
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.15);
            z-index: 101;
            border: 1px solid var(--border-color);
        }

        .card-type { 
            font-size: 0.7rem; 
            text-transform: uppercase; 
            letter-spacing: 1px; 
            padding: 4px 10px; 
            border-radius: 50px; 
            margin-bottom: 10px; 
            display: inline-block;
        }
        .type-main { background: #efecfd; color: var(--accent-main); }
        .type-secondary { background: #f1f2f6; color: var(--secondary-text); }

        h2 { margin: 0; color: #2d3436; font-size: 1.8rem; }
        .card-years { color: #b2bec3; font-size: 0.9rem; margin-bottom: 20px; display: block; }
        
        .section { margin-bottom: 15px; }
        .section-label { font-size: 0.75rem; font-weight: bold; color: #b2bec3; text-transform: uppercase; }
        .section-content { font-size: 0.95rem; line-height: 1.5; margin-top: 4px; }

        .close-btn { 
            position: absolute; top: 20px; right: 20px; 
            background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #b2bec3;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="timeline-line"></div>
    <div id="nodes-container"></div>
</div>

<div id="modal-overlay"></div>
<div id="info-card">
    <button class="close-btn" onclick="closeModal()">&times;</button>
    <div id="card-type-tag" class="card-type"></div>
    <h2 id="m-name"></h2>
    <span id="m-years" class="card-years"></span>
    
    <div class="section">
        <div class="section-label">Contexto Histórico</div>
        <div id="m-context" class="section-content"></div>
    </div>
    <div class="section">
        <div class="section-label">Ideas Doctrinales</div>
        <div id="m-ideas" class="section-content"></div>
    </div>
    <div class="section">
        <div class="section-label">Influencia</div>
        <div id="m-influence" class="section-content"></div>
    </div>
</div>

<script>
    const data = [
        { name: "PLATÓN", isMain: true, years: "427–347 a.C.", top: 40, left: 100, context: "Crisis de la polis ateniense tras la Guerra del Peloponeso y condena de Sócrates.", ideas: "Teoría de las Ideas (mundo sensible vs. inteligible). Política en La República. Dualismo alma-cuerpo.", influence: "Base del pensamiento filosófico occidental. Influye en Agustín." },
        { name: "Aristóteles", isMain: false, years: "384–322 a.C.", top: 110, left: 350, context: "Macedonia y expansión de Alejandro Magno.", ideas: "Lógica formal. Ética de la virtud. Observación empírica.", influence: "Base de la ciencia medieval. Fundamental en Tomás de Aquino." },
        { name: "Agustín de Hipona", isMain: false, years: "354–430", top: 220, left: 100, context: "Caída del Imperio romano y expansión del cristianismo.", ideas: "Interioridad. Confesiones. Ciudad de Dios. Síntesis platonismo-cristianismo.", influence: "Filosofía cristiana medieval." },
        { name: "Avicena", isMain: false, years: "980–1037", top: 300, left: 350, context: "Edad de oro del mundo islámico.", ideas: "Ser necesario vs. ser contingente. Psicología racional.", influence: "Impacto en la metafísica medieval." },
        { name: "San Anselmo", isMain: false, years: "1033–1109", top: 380, left: 100, context: "Consolidación Iglesia medieval.", ideas: "Argumento ontológico de la existencia de Dios.", influence: "Debates sobre fe y razón." },
        { name: "Averroes", isMain: false, years: "1126–1198", top: 460, left: 350, context: "Al-Ándalus.", ideas: "Comentarios a Aristóteles. Autonomía de la razón.", influence: "Transmisión de Aristóteles a Europa." },
        { name: "Averroísmo Latino", isMain: false, years: "S. XIII", top: 540, left: 550, context: "Auge universidades medievales.", ideas: "Unidad del intelecto. Autonomía de la filosofía.", influence: "Debates en la escolástica." },
        { name: "TOMÁS DE AQUINO", isMain: true, years: "1225–1274", top: 620, left: 100, context: "Universidades medievales y redescubrimiento de Aristóteles.", ideas: "Cinco vías. Síntesis fe-razón. Ley natural.", influence: "Filosofía oficial de la Iglesia." },
        { name: "DESCARTES", isMain: true, years: "1596–1650", top: 730, left: 100, context: "Revolución científica y crisis del aristotelismo.", ideas: "Duda metódica. Cogito ergo sum. Dualismo.", influence: "Padre de la modernidad." },
        { name: "Hobbes", isMain: false, years: "1588–1679", top: 810, left: 350, context: "Guerras civiles inglesas.", ideas: "Leviatán. Contrato social por seguridad.", influence: "Realismo político." },
        { name: "LOCKE", isMain: true, years: "1632–1704", top: 890, left: 100, context: "Revolución Gloriosa inglesa.", ideas: "Empirismo (tabula rasa). Derechos naturales (Vida, Libertad, Propiedad).", influence: "Liberalismo político." },
        { name: "Rousseau", isMain: false, years: "1712–1778", top: 970, left: 350, context: "Ilustración francesa.", ideas: "Voluntad general. El buen salvaje.", influence: "Revolución Francesa." },
        { name: "Kant", isMain: false, years: "1724–1804", top: 1050, left: 350, context: "Ilustración alemana.", ideas: "Imperativo categórico. Giro copernicano.", influence: "Filosofía crítica moderna." },
        { name: "Hegel", isMain: false, years: "1770–1831", top: 1130, left: 350, context: "Era napoleónica.", ideas: "Dialéctica. El Espíritu en la historia.", influence: "Idealismo alemán." },
        { name: "MARX", isMain: true, years: "1818–1883", top: 1220, left: 100, context: "Revolución Industrial y capitalismo.", ideas: "Materialismo histórico. Lucha de clases. Plusvalía.", influence: "Comunismo y sociología." },
        { name: "Nietzsche", isMain: false, years: "1844–1900", top: 1300, left: 350, context: "Crisis de valores europea.", ideas: "Superhombre. Voluntad de poder. Muerte de Dios.", influence: "Existencialismo." },
        { name: "Freud", isMain: false, years: "1856–1939", top: 1380, left: 350, context: "Nacimiento de la psicología.", ideas: "Inconsciente. Psicoanálisis.", influence: "Cultura contemporánea." },
        { name: "ARENDT", isMain: true, years: "1906–1975", top: 1470, left: 100, context: "Totalitarismos y postguerra.", ideas: "Banalidad del mal. Acción política. Vita activa.", influence: "Filosofía política actual." }
    ];

    const container = document.getElementById('nodes-container');

    data.forEach(p => {
        const div = document.createElement('div');
        div.className = `node ${p.isMain ? 'node-main' : 'node-secondary'}`;
        div.style.top = `${p.top}px`;
        div.style.left = `${p.left}px`;
        div.innerHTML = `<span class="name">${p.name}</span><span class="date">${p.years}</span>`;
        div.onclick = () => openModal(p);
        container.appendChild(div);
    });

    function openModal(p) {
        document.getElementById('m-name').innerText = p.name;
        document.getElementById('m-years').innerText = p.years;
        document.getElementById('m-context').innerText = p.context;
        document.getElementById('m-ideas').innerText = p.ideas;
        document.getElementById('m-influence').innerText = p.influence;
        
        const tag = document.getElementById('card-type-tag');
        tag.innerText = p.isMain ? "Autor Principal (PAU)" : "Autor Secundario / Contexto";
        tag.className = `card-type ${p.isMain ? 'type-main' : 'type-secondary'}`;

        document.getElementById('modal-overlay').style.display = 'block';
        document.getElementById('info-card').style.display = 'block';
    }

    function closeModal() {
        document.getElementById('modal-overlay').style.display = 'none';
        document.getElementById('info-card').style.display = 'none';
    }

    document.getElementById('modal-overlay').onclick = closeModal;
</script>

</body>
</html>
